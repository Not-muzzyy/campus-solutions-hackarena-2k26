# CampusIQ Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── MongoDB Atlas ──────────────────────────────────
MONGODB_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/campusiq?retryWrites=true&w=majority
DB_NAME=campusiq

# ── JWT Authentication ─────────────────────────────
JWT_SECRET=campusiq_super_secret_key_hackarena_2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Groq API (Free — LLaMA 3.1) ───────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile

# ── HuggingFace (Free — Embeddings) ───────────────
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Firebase (Optional — Push Notifications) ───────
# Leave blank if you don't have it — app will still work
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Encryption (Grievances) ────────────────────────
# Any 32+ character string — make up your own
GRIEVANCE_ENCRYPTION_KEY=campusiq_grievance_key_2026_secure

# ── CORS ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── App Config ─────────────────────────────────────
APP_ENV=development
APP_PORT=8000
